{
  "settings": {
  },
  "rules": [
    {
      "patterns": [
        ".*/new$",
        ".*/edit$",
        "/login$",
        "/registrations/new$"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web/modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [".*"],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true
      }
    }
  ]
}
