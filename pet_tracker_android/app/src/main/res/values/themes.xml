<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PetTrackerV4" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/amber_300</item>
        <item name="colorPrimaryVariant">#FFB300</item> <!-- amber_700 equivalent -->
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/amber_300</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">@color/amber_300</item>
        <!-- Use the standard app icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Set the theme to apply after the splash screen finishes -->
        <item name="postSplashScreenTheme">@style/Theme.PetTrackerV4</item>
    </style>
</resources>
