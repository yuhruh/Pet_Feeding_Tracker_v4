<div class="container mx-auto mb-4 mt-2">
  <div class="flex flex-col justify-center bg-gray-50 dark:bg-gray-800 border-2 border-gray-300 shadow-md rounded-lg p-4 sm:p-6">
    <div class="mx-auto mb-6">
      <h1 class="text-center font-semibold text-xl capitalize md:text-2xl lg:text-4xl"><%= t(".title", username: Current.user.username.split(' ').map(&:capitalize).join(" ")) %></h1>
    </div>

    <%= form_with(model: @user, url: users_path, method: :patch) do |form| %>
      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <label for="" class="text-base font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-right"><%= t(".username") %></label>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.text_field :username, value: @user.username, class: "shadow-md rounded-md border border-gray-400 focus:outline-softBlue px-3 py-2 w-1/2 dark:text-black", :required => true %>
        </div>
      </div>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <label for="" class="text-base font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-right"><%= t(".email") %></label>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.email_field :email_address, required: true, value: @user.email_address, class: "dark:text-black shadow-md rounded-md border border-gray-400 focus:outline-blue-400 px-3 py-2 w-1/2 #{'border-red-500' if form.object.errors[:email_address].any?}" %>
          <% form.object.errors.full_messages_for(:email_address).each do |message| %>
            <p class="text-red-500 text-sm italic mt-1">
              <%= message %>
            </p> 
          <% end %>
        </div>
      </div>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <label for="" class="text-base font-medium text-gray-700 dark:text-gray-100 optional capitalize md:text-right"><%= t(".password") %></label>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.password_field :password, placeholder: t(".password_placeholder"), class: "dark:text-black shadow-md rounded-md border border-gray-400 focus:outline-blue-400 px-3 py-2 w-1/2 #{'border-red-500' if form.object.errors[:password].any?}" %>
          <% form.object.errors.full_messages_for(:password).each do |message| %>
            <p class="text-red-500 text-sm italic mt-1">
              <%= message %>
            </p>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <label for="" class="text-base font-medium text-gray-700 dark:text-gray-100 optional capitalize md:text-right"><%= t(".password_confirmation") %></label>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.password_field :password_confirmation, autocomplete: "current-password", placeholder: t(".password_confirmation_placeholder"), class: "dark:text-black shadow-md rounded-md border border-gray-400 focus:outline-blue-400 px-3 py-2 w-1/2 #{'border-red-500' if form.object.errors[:password_confirmation].any?}" %>
          <% form.object.errors.full_messages_for(:password_confirmation).each do |message| %>
            <p class="text-red-500 text-sm italic mt-1">
              <%= message %>
            </p>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <%= form.label :gemini_api_key, class: "text-base font-medium text-gray-700 dark:text-gray-100 optional capitalize md:text-right" %>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.password_field :gemini_api_key, value: @user.gemini_api_key, placeholder: "AIza...", class: "shadow-md rounded-md border border-gray-400 focus:outline-softBlue px-3 py-2 w-1/2 bg-white text-gray-900" %>
          
          <details class="w-1/2 mt-4 bg-amber-50 dark:bg-gray-700 border border-amber-200 dark:border-gray-600 rounded-lg p-3 shadow-sm transition-all duration-300">
            <summary class="text-sm font-bold text-amber-800 dark:text-amber-400 cursor-pointer hover:text-amber-600 list-none flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= t(".gemini_api_key_instruction.title") %>
            </summary>
            
            <div class="mt-4 space-y-4 text-xs md:text-sm text-gray-700 dark:text-gray-200">
              <div class="flex items-start space-x-3">
                <div class="flex-shrink-0 w-6 h-6 bg-amber-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
                <div>
                  <%= t(".gemini_api_key_instruction.step_1") %>:
                  <a href="https://aistudio.google.com/" target="_blank" class="text-blue-600 dark:text-blue-400 underline font-semibold">
                    <%= t(".gemini_api_key_instruction.step_1_link") %>
                  </a>
                </div>
              </div>

              <div class="flex items-start space-x-3 border-l-2 border-amber-200 dark:border-gray-500 ml-3 pl-4">
                <div class="flex-shrink-0 w-6 h-6 bg-amber-500 text-white rounded-full flex items-center justify-center font-bold">2</div>
                <p class="pt-1"><%= t(".gemini_api_key_instruction.step_2") %></p>
              </div>

              <div class="flex items-start space-x-3 border-l-2 border-amber-200 dark:border-gray-500 ml-3 pl-4">
                <div class="flex-shrink-0 w-6 h-6 bg-amber-400 text-white rounded-full flex items-center justify-center font-bold">3</div>
                <p class="pt-1"><%= t(".gemini_api_key_instruction.step_3") %></p>
              </div>

              <div class="flex items-start space-x-3 border-l-2 border-amber-200 dark:border-gray-500 ml-3 pl-4">
                <div class="flex-shrink-0 w-6 h-6 bg-green-500 text-white rounded-full flex items-center justify-center font-bold">4</div>
                <p class="pt-1"><%= t(".gemini_api_key_instruction.step_4") %></p>
              </div>
              
              <div class="bg-white dark:bg-gray-800 p-2 rounded border border-gray-200 dark:border-gray-600 mt-2 italic text-[10px] text-gray-500">
                <%= t("shared.gemini_key_banner.message") %>
              </div>
            </div>
          </details>
        </div>
      </div>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row" data-controller="time-zone">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <%= form.label :timezone, t(".timezone"), class: "text-base font-medium text-gray-700 dark:text-gray-100 capitalize md:text-right" %>
        </div>
        <% if @user.timezone.blank? %>
          <div class="flex flex-col items-center md:items-start md:w-5/6">
            <%= form.text_field :timezone, data: {"time_zone_target" => "tz"}, class: "dark:text-black shadow-md rounded-md border border-gray-400 bg-gray-100 px-3 py-2 w-1/2 focus:outline-none", readonly: true %>
          </div>
        <% else %>
          <div class="flex flex-col items-center md:items-start md:w-5/6">
            <%= form.text_field :timezone, value: @user.timezone, class: "dark:text-black dark:bg-gray-300 shadow-md rounded-md border border-gray-400 bg-gray-100 px-3 py-2 w-1/2 focus:outline-none", readonly: true %>
            <span class="mt-2 text-sm italic"><%= t(".timezone_readonly_note") %></span>
          </div>
        <% end %>
      </div>

      <div class="flex flex-col justify-center items-center space-x-4 mb-4 md:flex-row">
        <div class="mb-4">
          <%= form.submit t(".update_profile_button"), class: "text-center rounded-md px-3.5 py-2.5 text-white bg-softBlue hover:bg-white hover:text-softBlue hover:border-2 hover:border-softBlue inline-block font-medium cursor-pointer" %>
        </div>
        <div class="mb-4">
          <%= link_to t(".cancel_button", username: @user.username.split(" ").map(&:capitalize).join(" ")), users_path, class: "text-center rounded-md px-3.5 py-2.5 text-white bg-grayishBlue hover:bg-white hover:text-grayishBlue hover:border-2 hover:border-grayishBlue inline-block font-medium cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>