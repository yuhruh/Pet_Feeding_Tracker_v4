<!DOCTYPE html>
<html  lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Aji Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag 'aji_favicon_32.png' %>

    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    
    <script type="module">
      import Big from "https://ga.jspm.io/npm:big.js@6.2.1/big.mjs";
      window.BigNumber = Big;
    </script>
    
    <%= javascript_include_tag "https://www.gstatic.com/charts/loader.js" %>
  </head>

  <body class="dark:bg-darkBlue dark:text-white">
    <%= render 'layouts/navigation' %>
    <%= render 'layouts/messages' %>
    
    <%= yield %>
  </body>
</html>
