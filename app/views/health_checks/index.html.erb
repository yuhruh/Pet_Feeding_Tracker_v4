<% content_for :title, "#{@pet.petname.capitalize}'s Health Reports" %>

<div class="container mx-auto border-4 border-amber-600 rounded-lg shadow-2xl mb-4 p-4 w-full">
  <div class="flex flex-col justify-center items-center">
    <div class="flex justify-center">
      <h1 class="text-center font-bold text-xl text-amber-700 mb-4 mt-2 underline underline-offset-8 decoration-amber-700 dark:text-amber-600 dark:decoration-amber-600 md:text-3xl">Annual Health Check-up Report</h1>
    </div>
  </div>

  <div id="health_checks">

    <div class="flex flex-col justify-center items-center gap-4 mt-2 md:flex-row">
      <div class="flex justify-center">
        <%= image_tag "aji_health_checkup.png", class: "rounded-xl shadow-lg w-full md:w-1/2 mb-4" %>
      </div>
    </div>
    <div class="flex flex-col md:flex-row justify-center items-center md:space-x-4 space-y-2 md:space-y-0 mb-4 text-amber-600 font-bold">
      <%= link_to "Liver", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Kidney", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Pancreas", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Stomach", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Pancreatic Islet", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Others", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "Blood", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
      <span class="hidden md:inline">|</span>
      <%= link_to "All", root_path, class: "hover:underline hover:scale-110 transition-all duration-300" %>
    </div>

    <div class="flex flex-col justify-center items-center gap-4 m-2">
      <%= form_with url: bulk_delete_pet_health_checks_path(@pet), method: :delete, data: { confirm: "Are you sure you want to delete the selected health checks?" } do |form| %>
        <% if @health_checks.any? %>
          <div class="flex justify-start mt-4">
            <%= form.submit "Delete Selected", class: "ml-4 p-2 rounded-md shadow-lg font-semibold border-2 border-red-300 text-gray-700 bg-red-200 hover:bg-gray-100 hover:border-gray-300 hover:text-red-700 hover:scale-110" %>
          </div>
          <%= render 'health_check' %>
          <div class="flex justify-center items-center gap-2 mt-2">
            <%= link_to new_pet_health_check_path, class: "text-center rounded-md px-3.5 py-2.5 text-white bg-gray-600 hover:bg-white hover:text-gray-600 hover:border-2 hover:border-gray-600 inline-flex items-center font-medium cursor-pointer" do %>
              <svg width="25px" height="25px" viewBox="0 0 48 48" version="1" xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 48 48" class="mr-2">
                <circle fill="#4CAF50" cx="24" cy="24" r="21"/>
                <g fill="currentColor">
                    <rect x="21" y="14" width="6" height="20"/>
                    <rect x="14" y="21" width="20" height="6"/>
                </g>
              </svg>
              Add new report
            <% end %>
          </div>
        <% else %>
          <div class="flex flex-col md:flex-row justify-center items-center md:space-x-4 space-y-2 md:space-y-0 mb-4 font-bold"> 
            <p class="text-amber-700 text-center my-10">No <%= @pet.petname.capitalize %>'s health checks found. Add Report Right now!!</p>
            <%= link_to new_pet_health_check_path, class: "items-center hover:scale-110 transition-all duration-300 font-medium" do %>
              <span class="sr-only">Add new report</span>
              <svg version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
                  width="25px" height="25px" viewBox="0 0 512.002 512.002" style="enable-background:new 0 0 512.002 512.002;" xml:space="preserve">
                <path style="fill:#FFFFFF;" d="M437.783,54.045c0-22.763-18.453-41.216-41.216-41.216H115.435
                  c-22.763,0-41.216,18.453-41.216,41.216v403.912c0,22.763,18.453,41.216,41.216,41.216h197.978l124.37-124.37V54.045z"/>
                <path style="fill:#80D0E1;" d="M437.783,374.801h-83.154c-22.763,0-41.216,18.453-41.216,41.216v83.154L437.783,374.801z"/>
                <path style="fill:#FF7876;" d="M278.897,213.052v-28.259c0-3.666,2.971-6.637,6.637-6.637h28.259c3.666,0,6.637-2.971,6.637-6.637
                  v-32.518c0-3.666-2.971-6.637-6.637-6.637h-28.259c-3.666,0-6.637-2.971-6.637-6.637V97.469c0-3.666-2.971-6.637-6.637-6.637h-32.52
                  c-3.666,0-6.637,2.971-6.637,6.637v28.259c0,3.666-2.971,6.637-6.637,6.637h-28.259c-3.666,0-6.637,2.971-6.637,6.637v32.52
                  c0,3.666,2.971,6.637,6.637,6.637h28.259c3.666,0,6.637,2.971,6.637,6.637v28.259c0,3.666,2.971,6.637,6.637,6.637h32.52
                  C275.926,219.689,278.897,216.718,278.897,213.052z"/>
                <g>
                  <path style="fill:#58595B;" d="M450.611,54.045c0-29.8-24.245-54.045-54.045-54.045H115.435C85.635,0,61.39,24.245,61.39,54.045
                    v403.912c0,29.8,24.245,54.045,54.045,54.045h197.978c3.3,0,6.606-1.295,9.072-3.758l124.37-124.368
                    c2.282-2.282,3.756-5.559,3.756-9.071L450.611,54.045L450.611,54.045z M87.048,457.955V54.045
                    c0-15.653,12.735-28.387,28.387-28.387h281.131c15.653,0,28.387,12.735,28.387,28.387v307.93h-70.325
                    c-29.8,0-54.045,24.243-54.045,54.043v70.325H115.435C99.782,486.343,87.048,473.608,87.048,457.955z M326.241,468.201v-52.184
                    c0-15.653,12.733-28.386,28.387-28.386h52.184C398.257,396.186,334.554,459.886,326.241,468.201z"/>
                  <path style="fill:#58595B;" d="M137.545,309.881h236.913c7.087,0,12.829-5.744,12.829-12.829c0-7.085-5.742-12.829-12.829-12.829
                    H137.545c-7.085,0-12.829,5.744-12.829,12.829C124.716,304.138,130.46,309.881,137.545,309.881z"/>
                  <path style="fill:#58595B;" d="M137.545,373.17h130.43c7.087,0,12.829-5.744,12.829-12.829c0-7.085-5.742-12.829-12.829-12.829
                    h-130.43c-7.085,0-12.829,5.744-12.829,12.829C124.716,367.426,130.46,373.17,137.545,373.17z"/>
                  <path style="fill:#58595B;" d="M267.975,410.8h-130.43c-7.085,0-12.829,5.744-12.829,12.829c0,7.085,5.744,12.829,12.829,12.829
                    h130.43c7.087,0,12.829-5.744,12.829-12.829C280.804,416.543,275.06,410.8,267.975,410.8z"/>
                </g>
              </svg>
            <% end %>
          </div>
        <% end %>
        <div class="flex flex-row justify-center items-center gap-2 mt-2">
          <%= link_to "Go Back to Home", root_path, class: "text-center rounded-md px-3.5 py-2.5 text-white bg-amber-600 hover:bg-white hover:text-amber-600 hover:border-2 hover:border-amber-600 inline-block font-medium cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>