<% content_for :title, t('.title') %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl"><%= t('.title') %></h1>

  <%= render 'health_check' %>

  <%= link_to t('.edit'), edit_pet_health_check_path(@health_check), class: "mt-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to t('.back'), pet_health_checks_path, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <div class="inline-block ml-2">
    <%= button_to t('.destroy'), pet_health_check_path(@pet, @health_check), method: :delete, class: "mt-2 rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium" %>
  </div>
</div>
