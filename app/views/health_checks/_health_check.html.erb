<div class="flex flex-col justify-center items-center">
  <div class="flex justify-center mb-2">
    <h1 class="text-center font-bold text-xl text-amber-700 mb-2 mt-2 p-4 underline underline-offset-8 decoration-amber-700 dark:text-amber-600 dark:decoration-amber-600 md:text-3xl">Annual Health Check-up Reports</h1>
  </div>
  <%= form_with url: bulk_delete_pet_health_checks_path(@pet), method: :delete, data: { confirm: "Are you sure you want to delete the selected health checks?"} do |form| %>
    <% if @health_checks.any? %>
      <div class="flex justify-start mt-4 ml-4">
        <%= form.submit "Delete Selected", class: "p-2 rounded-md shadow-lg font-semibold border-2 border-red-300 text-gray-700 bg-red-200 hover:bg-gray-100 hover:border-gray-300 hover:text-red-700 hover:scale-110" %>
      </div>
      <div class="container mx-auto w-full shadow-lg rounded-xl p-4 mb-4" data-controller="bulk-delete">
        <div class="overflow-x-auto w-full">
          <div class="hidden overflow-x-auto w-full md:block">
            <table class="table-auto mb-2 px-2 w-full dark:bg-slate-100">
              <thead>
                <tr class="bg-gray-100 dark:bg-black">
                  <th class="capitalize text-sm text-center p-2 dark:text-white">
                    <input type="checkbox" data-bulk-delete-target="selectAll" data-action="bulk-delete#toggleAll">
                  </th>
                  <th class="text-sm text-center p-2 dark:text-white">#</th>
                  <th class="text-sm text-center p-2 dark:text-white">Exam Date</th>
                  <th class="text-sm text-center p-2 dark:text-white">RBC(M/µl)</th>
                  <th class="text-sm text-center p-2 dark:text-white">HCT(%)</th>
                  <th class="text-sm text-center p-2 dark:text-white">HGB(g/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">MCV(fL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">MCH(pg)</th>
                  <th class="text-sm text-center p-2 dark:text-white">MCHC(g/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">RDW(%)</th>
                  <th class="text-sm text-center p-2 dark:text-white">RETIC(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">RETIC-HGB(pg)</th>
                  <th class="text-sm text-center p-2 dark:text-white">WBC(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">NEU(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">LYM(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">MONO(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">EOS(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">BASO(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">PLT(K/µL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">MPV(fL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">PCT(%)</th>
                  <th class="text-sm text-center p-2 dark:text-white">GLU(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">CREA(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">BUN(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">PHOS(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">TP(g/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">ALB(g/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">GLOB(g/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">ALT(U/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">ALKP(U/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">Na(mmol/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">K(mmol/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">Cl(mmol/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">CA(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">CHOL(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">GGT(U/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">TBIL(mg/dL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">AMYL(U/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">fPL2(ng/mL)</th>
                  <th class="text-sm text-center p-2 dark:text-white">LIPA(U/L)</th>
                  <th class="text-sm text-center p-2 dark:text-white">Osm Calc(mmol/kg)</th>
                  <th class="text-sm text-center p-2 dark:text-white">fBNP</th>
                  <th class="text-sm text-center p-2 dark:text-white">FeLV</th>
                  <th class="text-sm text-center p-2 dark:text-white">FIV</th>
                  <th class="capitalize text-sm text-center p-2 dark:text-white">edit</th>
                  <th class="capitalize text-sm text-center p-2 dark:text-white">delete</th>
                </tr>
              </thead>
              <thead>
                  <tr class="border-b-4 bg-gray-100 dark:bg-black">
                    <th class="text-sm text-center p-2 dark:text-white"></th>
                    <th class="text-sm text-center p-2 dark:text-white"></th>
                    <th class="text-sm text-center p-2 dark:text-white">Reference Range</th>
                    <th class="text-sm text-center p-2 dark:text-white">6.54 - 12.20 (M/µl)</th>
                    <th class="text-sm text-center p-2 dark:text-white">30.3 - 52.3 (%)</th>
                    <th class="text-sm text-center p-2 dark:text-white">9.8 - 16.2 (g/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">35.9 - 53.1 (fL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">11.8 - 17.3 (pg)</th>
                    <th class="text-sm text-center p-2 dark:text-white">28.1 - 35.8 (g/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">15.0 - 27.0 (%)</th>
                    <th class="text-sm text-center p-2 dark:text-white">3.0 - 50.0 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">13.2 - 20.8 (pg)</th>
                    <th class="text-sm text-center p-2 dark:text-white">2.87 - 17.02 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">2.30 - 10.29 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.92 - 6.88 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.05 - 0.67 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.17 - 1.57 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.01 - 0.26 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">151 - 600 (K/µL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">11.4 - 21.6 (fL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.17 - 0.86 (%)</th>
                    <th class="text-sm text-center p-2 dark:text-white">74 - 159 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.8 - 2.4 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">16 - 36 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">3.1 - 7.5 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">5.7 - 8.9 (g/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">2.2 - 4.0 (g/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">2.8 - 5.1 (g/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">12 - 130 (U/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">14 - 111 (U/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">150 - 165 (mmol/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">3.5 - 5.8 (mmol/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">112 - 129(mmol/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">7.8 - 11.3 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">65 - 225 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0 - 4 (U/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">0.0 - 0.9 (mg/dL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">500 - 1500 (U/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white"><= 3.5 (ng/mL)</th>
                    <th class="text-sm text-center p-2 dark:text-white">100 - 1400 (U/L)</th>
                    <th class="text-sm text-center p-2 dark:text-white">-</th>
                    <th class="text-sm text-center p-2 dark:text-white">-</th>
                    <th class="text-sm text-center p-2 dark:text-white">-</th>
                    <th class="text-sm text-center p-2 dark:text-white">-</th>
                    <th class="text-sm text-center p-2 dark:text-white"></th>
                    <th class="text-sm text-center p-2 dark:text-white"></th>
                  </tr>
                </thead>
              <tbody>
                <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
                  <tr id="<%= dom_id(health_check) %>" class="border-b bg-gray-100">
                    <td class="capitalize text-sky-700 text-sm text-center p-2">
                      <%= check_box_tag "health_check_ids[]", health_check.id, false, class: "health-check-checkbox", "data-bulk-delete-target": "checkbox", "data-action": "bulk-delete#updateSelectAll" %>
                    </td>
                    <td class="text-sm text-center p-2 font-semibold"><%= idx+1 %></td>
                    <td class="text-sm text-center p-2"><%= health_check.exam_date&.strftime("%Y-%m-%d") %></td>
                    <td class="text-sm <%=range_row_class(health_check.rbc, 12.20, 6.54)%> text-center p-2"><%= health_check.rbc %></td>
                    <td class="text-sm <%=range_row_class(health_check.hct, 52.3, 30.3)%> text-center p-2"><%= health_check.hct %></td>
                    <td class="text-sm <%=range_row_class(health_check.hgb, 16.2, 9.8)%> text-center p-2"><%= health_check.hgb %></td>
                    <td class="text-sm <%=range_row_class(health_check.mcv, 53.1, 35.9)%> text-center p-2"><%= health_check.mcv %></td>
                    <td class="text-sm <%=range_row_class(health_check.mch, 17.3, 11.8)%> text-center p-2"><%= health_check.mch %></td>
                    <td class="text-sm <%=range_row_class(health_check.mchc, 35.8, 28.1)%> text-center p-2"><%= health_check.mchc %></td>
                    <td class="text-sm <%=range_row_class(health_check.rdw, 27.0, 15.0)%> text-center p-2"><%= health_check.rdw %></td>
                    <td class="text-sm <%=range_row_class(health_check.retic, 50.0, 3.0)%> text-center p-2"><%= health_check.retic %></td>
                    <td class="text-sm <%=range_row_class(health_check.retic_hgb, 20.8, 13.2)%> text-center p-2"><%= health_check.retic_hgb %></td>
                    <td class="text-sm <%=range_row_class(health_check.wbc, 17.02, 2.87)%> text-center p-2"><%= health_check.wbc %></td>
                    <td class="text-sm <%=range_row_class(health_check.neu, 10.29, 2.30)%> text-center p-2"><%= health_check.neu %></td>
                    <td class="text-sm <%=range_row_class(health_check.lym, 6.88, 0.92)%> text-center p-2"><%= health_check.lym %></td>
                    <td class="text-sm <%=range_row_class(health_check.mono, 0.67, 0.05)%> text-center p-2"><%= health_check.mono %></td>
                    <td class="text-sm <%=range_row_class(health_check.eos, 1.57, 0.17)%> text-center p-2"><%= health_check.eos %></td>
                    <td class="text-sm <%=range_row_class(health_check.baso, 0.26, 0.01)%> text-center p-2"><%= health_check.baso %></td>
                    <td class="text-sm <%=range_row_class(health_check.plt, 600, 151)%> text-center p-2"><%= health_check.plt %></td>
                    <td class="text-sm <%=range_row_class(health_check.mpv, 21.6, 11.4)%> text-center p-2"><%= health_check.mpv %></td>
                    <td class="text-sm <%=range_row_class(health_check.pct, 0.86, 0.17)%> text-center p-2"><%= health_check.pct %></td>
                    <td class="text-sm <%=range_row_class(health_check.glu, 159, 74)%> text-center p-2"><%= health_check.glu %></td>
                    <td class="text-sm <%=range_row_class(health_check.crea, 2.4, 0.8)%> text-center p-2"><%= health_check.crea %></td>
                    <td class="text-sm <%=range_row_class(health_check.bun, 36, 16)%> text-center p-2"><%= health_check.bun %></td>
                    <td class="text-sm <%=range_row_class(health_check.phos, 7.5, 3.1)%> text-center p-2"><%= health_check.phos %></td>
                    <td class="text-sm <%=range_row_class(health_check.tp, 8.9, 5.7)%> text-center p-2"><%= health_check.tp %></td>
                    <td class="text-sm <%=range_row_class(health_check.alb, 4.0, 2.2)%> text-center p-2"><%= health_check.alb %></td>
                    <td class="text-sm <%=range_row_class(health_check.glob, 5.1, 2.8)%> text-center p-2"><%= health_check.glob %></td>
                    <td class="text-sm <%=range_row_class(health_check.alt, 130, 12)%> text-center p-2"><%= health_check.alt %></td>
                    <td class="text-sm <%=range_row_class(health_check.alkp, 111, 14)%> text-center p-2"><%= health_check.alkp %></td>
                    <td class="text-sm <%=range_row_class(health_check.na, 165, 150)%> text-center p-2"><%= health_check.na %></td>
                    <td class="text-sm <%=range_row_class(health_check.k, 5.8, 3.5)%> text-center p-2"><%= health_check.k %></td>
                    <td class="text-sm <%=range_row_class(health_check.cl, 129, 112)%> text-center p-2"><%= health_check.cl %></td>
                    <td class="text-sm <%=range_row_class(health_check.ca, 11.3, 7.8)%> text-center p-2"><%= health_check.ca %></td>
                    <td class="text-sm <%=range_row_class(health_check.chol, 225, 65)%> text-center p-2"><%= health_check.chol %></td>
                    <td class="text-sm <%=range_row_class(health_check.ggt, 4, 0)%> text-center p-2"><%= health_check.ggt %></td>
                    <td class="text-sm <%=range_row_class(health_check.tbil, 0.9, 0.0)%> text-center p-2"><%= health_check.tbil %></td>
                    <td class="text-sm <%=range_row_class(health_check.amyl, 1500, 500)%> text-center p-2"><%= health_check.amyl %></td>
                    <td class="text-sm <%=range_row_class(health_check.fpl2, 3.5, 0)%> text-center p-2"><%= health_check.fpl2 %></td>
                    <td class="text-sm <%=range_row_class(health_check.lipa, 1400, 100)%> text-center p-2"><%= health_check.lipa %></td>
                    <td class="text-sm font-normal text-center p-2"><%= health_check.osm_cal %></td>
                    <td class="text-sm font-normal text-center p-2"><%= health_check.fbnp %></td>
                    <td class="text-sm font-normal text-center p-2"><%= health_check.felv %></td>
                    <td class="text-sm font-normal text-center p-2"><%= health_check.fiv %></td>                  
                    <td class="text-sm text-center p-2">
                      <%= link_to edit_pet_health_check_path(@pet, health_check), id: "edit_health_check_#{health_check.id}", class: "inline-block transition-transform text-emerald-400 hover:text-emerald-600 hover:scale-110" do %>
                        <span class="sr-only">Edit this health check</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z" />
                          <path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    </td>
                    <td class="text-sky-700 test-sm text-center p-2">
                      <%= link_to pet_health_check_path(@pet, health_check), data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this health check?' }, class: "inline-block transition-transform text-red-400 hover:text-red-600 hover:scale-110" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
            <ul class="list-disc list-inside ml-4">
              <li class="text-red-700 font-bold italic mt-2">Red means the value is higher than reference range</li>
              <li class="text-sky-700 font-bold italic mt-2">Blue means the value is lower than reference range</li>
            </ul>
          </div>

          <!-- Transposed Table for Small Screens -->
          
        </div>
      </div>
    <% else %>
    <% end %>
  <% end %>
</div>