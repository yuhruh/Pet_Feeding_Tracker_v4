<div class="container mx-auto w-full shadow-lg rounded-xl p-2 mb-4" data-controller="bulk-delete">
  <div class="flex flex-col gap-8 justify-center mt-4 lg:flex-row lg:items-center">
    <div class="hidden overflow-x-auto w-full md:block">
      <table class="table-auto mb-2 px-2 w-full dark:bg-slate-100">
        <thead>
          <tr class="border-b-4 bg-gray-100 dark:bg-black">
            <th class="capitalize text-sm text-center p-2 dark:text-white">
              <input type="checkbox" data-bulk-delete-target="selectAll" data-action="bulk-delete#toggleAll">
            </th>
            <th class="text-sm text-center p-2 dark:text-white">#</th>
            <th class="text-sm text-center p-2 dark:text-white">Exam Date</th>
            <th class="text-sm text-center p-2 dark:text-white">RBC(M/µl)</th>
            <th class="text-sm text-center p-2 dark:text-white">HCT(%)</th>
            <th class="text-sm text-center p-2 dark:text-white">HGB(g/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">MCV(fL)</th>
            <th class="text-sm text-center p-2 dark:text-white">MCH(pg)</th>
            <th class="text-sm text-center p-2 dark:text-white">MCHC(g/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">RDW(%)</th>
            <th class="text-sm text-center p-2 dark:text-white">RETIC(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">RETIC-HGB(pg)</th>
            <th class="text-sm text-center p-2 dark:text-white">WBC(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">NEU(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">LYM(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">MONO(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">EOS(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">BASO(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">PLT(K/µL)</th>
            <th class="text-sm text-center p-2 dark:text-white">MPV(fL)</th>
            <th class="text-sm text-center p-2 dark:text-white">PCT(%)</th>
            <th class="text-sm text-center p-2 dark:text-white">GLU(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">CREA(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">BUN(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">PHOS(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">TP(g/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">ALB(g/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">ALT(U/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">ALKP(U/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">Na(mmol/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">K(mmol/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">Cl(mmol/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">CA(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">CHOL(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">GGT(U/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">TBIL(mg/dL)</th>
            <th class="text-sm text-center p-2 dark:text-white">AMYL(U/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">LIPA(U/L)</th>
            <th class="text-sm text-center p-2 dark:text-white">Osm Calc(mmol/kg)</th>
            <th class="capitalize text-sm text-center p-2 dark:text-white">edit</th>
            <th class="capitalize text-sm text-center p-2 dark:text-white">delete</th>
          </tr>
        </thead>
        <tbody>
          <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
            <tr id="<%= dom_id(health_check) %>" class="border-b bg-gray-100">
              <td class="capitalize text-sky-700 text-sm text-center p-2">
                <%= check_box_tag "health_check_ids[]", health_check.id, false, class: "health-check-checkbox", "data-bulk-delete-target": "checkbox", "data-action": "bulk-delete#updateSelectAll" %>
              </td>
              <td class="text-sky-700 text-sm text-center p-2 font-semibold"><%= idx+1 %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.exam_date&.strftime("%Y-%m-%d") %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.rbc %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.hct %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.hgb %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.mcv %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.mch %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.mchc %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.rdw %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.retic %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.retic_hgb %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.wbc %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.neu %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.lym %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.mono %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.eos %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.baso %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.plt %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.mpv %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.pct %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.glu %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.crea %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.bun %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.phos %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.tp %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.alb %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.alt %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.alkp %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.na %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.k %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.cl %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.ca %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.chol %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.ggt %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.tbil %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.amyl %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.lipa %></td>
              <td class="text-sky-700 text-sm text-center p-2"><%= health_check.osm_cal %></td>                
              <td class="text-sky-700 text-sm text-center p-2">
                <%= link_to edit_pet_health_check_path(@pet, health_check), class: "inline-block transition-transform text-emerald-400 hover:text-emerald-600 hover:scale-110" do %>
                  <span class="sr-only">Edit this health check</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z" />
                    <path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              </td>
              <td class="text-sky-700 test-sm text-center p-2">
                <%= link_to(pet_health_check_path(@pet, health_check), data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this health check?' }, class: "inline-block transition-transform text-red-400 hover:text-red-600 hover:scale-110") do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Transposed Table for Small Screens -->
    
  </div>
</div>