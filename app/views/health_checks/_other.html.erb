        <% end %>
      </div>
    </div>
  </div>
  <% if @health_checks.empty? %>
    <p class="text-amber-700 text-center font-bold my-10"><%= t('health_checks.index.no_report', petname: @pet.petname.capitalize, organ: t("health_checks.index.organs.other")) %></p>
    <div class="flex flex-col lg:flex-row justify-center items-center lg:space-x-4">
      <%= link_to t('.back_link'), pet_health_checks_path, class: "mb-4 items-center text-center rounded-md px-3.5 py-2.5 text-white bg-amber-600 hover:bg-white hover:text-amber-600 hover:border-2 hover:border-amber-600 inline-block font-medium cursor-pointer" %>
    </div>
  <% else %>
    <div class="container mx-auto w-full shadow-lg rounded-xl p-4 mb-4">
      <div class="hidden lg:block overflow-auto max-h-[70vh] w-full shadow-inner">
        <table class="table-auto mb-2 mx-auto min-w-full dark:bg-slate-100 border-separate border-spacing-0">
          <thead>
            <tr class="bg-gray-100 dark:bg-black">
              <th class="sticky top-0 left-0 z-30 bg-gray-100 dark:bg-black border-b-4 border-gray-200 dark:border-gray-800 text-sm text-center p-2 dark:text-white">#</th>
              <th class="sticky top-0 z-20 bg-gray-100 dark:bg-black border-b-4 border-gray-200 dark:border-gray-800 text-sm text-center p-2 dark:text-white"><%= t('health_checks.health_check.exam_date') %></th>
              <th class="sticky top-0 z-20 bg-gray-100 dark:bg-black border-b-4 border-gray-200 dark:border-gray-800 text-sm text-center p-2 dark:text-white">FeLV</th>
              <th class="sticky top-0 z-20 bg-gray-100 dark:bg-black border-b-4 border-gray-200 dark:border-gray-800 text-sm text-center p-2 dark:text-white">FIV</th>
            </tr>
          </thead>
          <tbody>
            <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
              <tr id="<%= dom_id(health_check) %>" class="border-b bg-gray-100">
                <td class="sticky left-0 z-10 bg-gray-100 dark:bg-black text-sm text-center p-2 font-semibold dark:text-gray-800"><%= idx+1 %></td>
                <td class="text-sm text-center p-2 dark:text-gray-800"><%= health_check.exam_date&.strftime("%Y-%m-%d") %></td>
                <td class="text-sm capitalize font-normal text-center p-2 dark:text-gray-800"><%= health_check.felv %></td>
                <td class="text-sm capitalize font-normal text-center p-2 dark:text-gray-800"><%= health_check.fiv %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <ul class="list-disc list-inside ml-4">
          <li class="text-red-700 font-bold italic mt-2">Red means the value is abnormal</li>
        </ul>
      </div>
      <!-- Transposed Table for Small Screens -->
      <div class="overflow-x-auto lg:hidden">
        <table class="table-auto mb-2 mx-auto min-w-full">
          <tr class="border-b bg-gray-100">
            <th class="sticky left-0 z-10 bg-gray-100 dark:bg-black capitalize text-sm text-left p-2 border-r dark:bg-black whitespace-nowrap">#</th>
            <th class="capitalize text-sm text-left p-2 border-r-4 dark:bg-black whitespace-nowrap"></th>
            <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
              <td class="capitalize text-sm text-center p-2 font-semibold dark:text-gray-800"><%= idx+1 %></td>
            <% end %>
          </tr>
          <tr class="border-b bg-gray-100">
            <th class="sticky left-0 z-10 bg-gray-100 dark:bg-black capitalize text-sm text-left p-2 border-r dark:bg-black whitespace-nowrap"><%= t('health_checks.health_check.exam_date') %></th>
            <th class="capitalize text-sm text-left p-2 border-r-4 dark:bg-black whitespace-nowrap"></th>
            <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
              <td class="capitalize text-sm text-center dark:text-gray-800 p-2"><%= health_check.exam_date&.strftime("%Y-%m-%d") %></td>
            <% end %>
          </tr>
          <tr class="border-b bg-gray-100">
            <th class="sticky left-0 z-10 bg-gray-100 dark:bg-black capitalize text-sm text-left p-2 border-r dark:bg-black whitespace-nowrap">FeLV</th>
            <th class="capitalize text-sm text-left p-2 border-r-4 dark:bg-black whitespace-nowrap"></th>
            <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
              <td class="capitalize font-normal text-sm text-center dark:text-gray-800 p-2"><%= health_check.felv %></td>
            <% end %>
          </tr>
          <tr class="border-b bg-gray-100">
            <th class="sticky left-0 z-10 bg-gray-100 dark:bg-black capitalize text-sm text-left p-2 border-r dark:bg-black whitespace-nowrap">FIV</th>
            <th class="capitalize text-sm text-left p-2 border-r-4 dark:bg-black whitespace-nowrap"></th>
            <% @health_checks.select(&:persisted?).each_with_index do |health_check, idx| %>
              <td class="capitalize font-normal text-sm text-center dark:text-gray-800 p-2"><%= health_check.fiv %></td>
            <% end %>
          </tr>
        </table>
        <ul class="list-disc list-inside ml-4">
          <li class="text-red-700 font-bold italic mt-2">Red means the value is abnormal</li>
        </ul>
      </div>  
    </div>
  <% end %>
</div>