<div data-controller="ocr-upload" 
     data-ocr-upload-pet-id-value="<%= @pet.id %>"
     data-ocr-upload-status-reading-value="<%= t('shared.ocr_auto_fill.status_reading') %>"
     data-ocr-upload-status-success-value="<%= t('shared.ocr_auto_fill.status_success') %>"
     data-ocr-upload-status-error-value="<%= t('shared.ocr_auto_fill.status_error') %>"
     data-ocr-upload-status-failed-value="<%= t('shared.ocr_auto_fill.status_failed') %>"
     data-ocr-upload-page-singular-value="<%= t('shared.ocr_auto_fill.page_singular') %>"
     data-ocr-upload-page-plural-value="<%= t('shared.ocr_auto_fill.page_plural') %>">
  <div class="container mx-auto mb-8 p-6 bg-amber-50 border-2 border-dashed border-amber-400 rounded-xl shadow-inner">
    <div class="flex flex-col items-center justify-center space-y-4">
      <div class="flex items-center space-x-2">
        <%= image_tag('aji_icon_512.png', width: '40px', class: 'opacity-80') %>
        <h3 class="text-lg font-bold text-amber-800 uppercase tracking-wide"><%= t('shared.ocr_auto_fill.title') %></h3>
      </div>
      <p class="text-sm text-amber-700 text-center max-w-full italic"><%= t('shared.ocr_auto_fill.description') %></p>
      
      <div class="relative group">
        <input type="file" 
               accept="image/*" 
               data-action="change->ocr-upload#upload" 
               data-ocr-upload-target="fileInput"
               class="hidden" 
               id="ocr_file_upload"
               multiple>
        <label for="ocr_file_upload" 
               class="cursor-pointer inline-flex items-center px-6 py-3 bg-amber-600 text-white font-bold rounded-lg shadow-md hover:bg-amber-700 hover:scale-105 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          <%= t('shared.ocr_auto_fill.select_button') %>
        </label>
      </div>

      <div data-ocr-upload-target="loader" class="hidden flex items-center space-x-2 animate-pulse">
        <div class="w-3 h-3 bg-amber-600 rounded-full"></div>
        <div class="w-3 h-3 bg-amber-600 rounded-full"></div>
        <div class="w-3 h-3 bg-amber-600 rounded-full"></div>
      </div>
      
      <p data-ocr-upload-target="status" class="text-sm font-semibold mt-2 text-gray-600"></p>
    </div>
  </div>

