<div class="flex flex-col justify-center items-center">
  <div class="flex justify-center">
    <h1 class="text-center font-bold text-xl text-amber-700 mb-4 mt-2 p-4 underline underline-offset-8 decoration-amber-700 dark:text-amber-600 dark:decoration-amber-600 md:text-3xl">Kidney Health Report</h1>
    <div class="flex flex-row justify-center items-center gap-4 mt-2">
