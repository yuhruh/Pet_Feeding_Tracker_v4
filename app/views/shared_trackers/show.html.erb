<% content_for :title, t('trackers.index.title', petname: @pet.petname.capitalize) + " (Shared)" %>

<div class="container mx-auto py-8">
  <div class="flex flex-col justify-center items-center mb-6">
    <h1 class="font-bold text-center text-2xl md:text-4xl"><%= t('trackers.index.title', petname: @pet.petname.capitalize) %></h1>
    <p class="underline decoration-double underline-offset-4 text-gray-500 italic mt-2"><%= t('shared_trackers.read_only_view') %></p>
  </div>
  
  <%# Chart Section %>
  <div class="flex flex-col mb-8 justify-center items-center mx-auto w-full lg:w-11/12">
    <div class="flex justify-end items-end pr-8 pt-4 mb-4 w-full" data-controller="range-form">
      <div class="relative">
        <div class="inline-flex w-full justify-center px-3 py-2 inset-ring-1 inset-ring-gray-300 cursor-pointer">
          <%= form_with url: shared_pet_trackers_path(share_token: @pet.share_token), method: :get, class: "flex items-center" do |form| %>
            <span class="mr-2"><%= t('trackers.index.chart_range') %></span>
            <%= form.select :range, options_for_select([[t('trackers.index.all_time'), "all"], [t('trackers.index.last_7_days'), "7"], 
            [t('trackers.index.last_30_days'), "30"], ["Last 120 days", "120"], ["Last 180 days", "180"], ["Year To Date", "YTD"], ["Custom", "custom"]], params[:range] || "all"), {}, 
            { data: { action: "change->range-form#toggleForm" }, class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 
            hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700" } %>
          <% end %>
        </div>
        <div data-range-form-target="form" class="absolute hidden w-max top-full mt-2 py-2 z-30">
          <%= form_with url: shared_pet_trackers_path(share_token: @pet.share_token), method: :get, class: "flex items-center ml-4" do |form| %>
            <div class= "inline-flex w-full justify-center bg-white px-3 py-2 text-grayishBlue rounded-md shadow-lg tracking-wide inset-ring-1 inset-ring-gray-300 dark:bg-darkBlue cursor-pointer">
              <%= form.hidden_field :range, value: "custom" %>
                <div class="flex flex-col items-center gap-4">
                  <div class="flex items-center">
                    <span class="mr-2"><%= t('trackers.index.start_date') %></span>
                    <%= form.date_field :start_date, value: params[:start_date], class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200", min: @min_date, max: @max_date %>
                  </div>
                  <div class="flex items-center">
                    <span class="mr-2"><%= t('trackers.index.end_date') %></span>
                    <%= form.date_field :end_date, value: params[:end_date], class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200", min: @min_date, max: @max_date %>
                  </div>
                  <div class="flex items-center">
                    <%= form.submit "Apply Custom Range", class: "p-2 ml-4 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700" %>
                  </div>
                </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="relative w-full px-8 py-8 md:px-12 md:py-12 mx-auto">
      <!-- Left Overlay (Amount) -->
      <div class="absolute left-2 md:left-4 top-[42%] w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block -rotate-90 capitalize whitespace-nowrap font-bold text-base text-gray-600 dark:text-gray-100">
          <%= t('trackers.index.chart_v_axis_amount') %>
        </span>
      </div>

      <!-- Right Overlay (Weight) -->
      <div class="absolute right-2 md:right-4 top-[42%] w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block -rotate-90 capitalize whitespace-nowrap font-bold text-base text-gray-600 dark:text-gray-100">
          <%= t('trackers.index.chart_v_axis_weight') %>
        </span>
      </div>

      <!-- Title Overlay (amount vs. weight) -->
      <div class="absolute left-1/2 -translate-x-1/2 top-8 w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block capitalize whitespace-nowrap font-bold text-lg text-gray-700 dark:text-gray-200">
          <%= t('trackers.index.chart_title') %>
        </span>
      </div>

      <div class="relative w-full border border-gray-100 rounded-lg shadow-sm bg-white dark:bg-slate-800 overflow-hidden">
        
        <!-- 1. Scrolling Data Chart -->
        <div id="chart-container" class="w-full overflow-x-auto relative z-0 custom-scrollbar">
          <% chart_width = [@data.first[:data].size * 15, 800].max %>
          <div style="min-width: <%= chart_width%>px;">
            <% if @dry_properties.present? || @wet_properties.present? %>
              <%= column_chart @data, adapter: "google", height: "350px", id: "pet-chart-scrolling", library: {
                isStacked: true,
                interpolateNulls: true,
                series: {
                  0 => {type: 'bar', targetAxisIndex: 0},
                  1 => {type: 'bar', targetAxisIndex: 0},
                  2 => {type: 'bar', targetAxisIndex: 0},
                  3 => {type: 'bar', targetAxisIndex: 0},
                  4 => {type: 'line', targetAxisIndex: 1, pointSize: 5}
                },
                colors: ['#C1D7EC', '#2563EB', '#FFDAB9','#F97316', '#6B4AB9'],
                bar: {groupWidth: '75%'},
                chartArea: {left: 60, right: 60, bottom: 100, top: 40},
                hAxis: {
                  title: t('trackers.index.chart_h_axis_title'),
                  showTextEvery: @chart_interval,
                  slantedText: true,
                  slantedTextAngle: 45,
                  format: 'yyyy/MM/dd',
                  textStyle: {fontSize: 8}
                },
                vAxes: {
                  0 => {title: "", textPosition: 'none'},
                  1 => {title: "", textPosition: 'none', viewWindow: {min: @min_weight, max: @max_weight}, gridlines: {color: 'transparent'}}
                },
                legend: {position: 'top', alignment: 'center'}
              } %>
            <% else %>            
              <div class="text-center p-8 my-4 bg-gray-100 rounded-lg shadow-lg">
                <p class="font-semibold text-gray-700"><%= t('trackers.index.no_data_for_chart') %></p>
              </div>
            <% end %>
          </div>
        </div>

        <% if @dry_properties.present? || @wet_properties.present? %>
          <!-- 2. Solid Background Masks (Hides bars scrolling under axes) -->
          <div class="absolute left-0 top-[40px] bottom-[100px] w-[60px] bg-white z-10 pointer-events-none"></div>
          <div class="absolute right-0 top-[40px] bottom-[100px] w-[60px] bg-white z-10 pointer-events-none"></div>

          <!-- 3. Fixed Axes Chart Overlay -->
          <div class="absolute inset-0 z-20 pointer-events-none">
            <%= column_chart @data, adapter: "google", height: "350px", id: "pet-chart-fixed", library: {
              isStacked: true,
              interpolateNulls: true,
              series: {
                0 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                1 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                2 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                3 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                4 => {type: 'line', targetAxisIndex: 1, visibleInLegend: false}
              },
              colors: ['transparent', 'transparent', 'transparent', 'transparent', 'transparent'],
              backgroundColor: 'transparent',
              chartArea: {left: 60, right: 60, bottom: 100, top: 40},
              hAxis: { textPosition: 'none', baselineColor: 'transparent', gridlines: {color: 'transparent'} },
              vAxes: {
                0 => {title: "", gridlines: {color: 'transparent'}},
                1 => {title: "", viewWindow: {min: @min_weight, max: @max_weight}, gridlines: {color: 'transparent'}}
              },
              legend: {position: 'none'}
            } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Data Table %>
  <div class="overflow-x-auto shadow-lg rounded-xl">
    <table class="table-auto w-full dark:bg-slate-100">
      <thead>
        <tr class="bg-gray-100 dark:bg-black">
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.number') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.date') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.time') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.hungry') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.come_back_to_eat') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.food_type') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.brand') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.description') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.amount') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.left_amount') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.total_ate_amount') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.result') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.weight') %></th>
          <th class="capitalize text-sm text-center p-2 dark:text-white"><%= t('trackers.tracker.note') %></th>
        </tr>
      </thead>
      <tbody>
        <% @trackers.each_with_index do |record, idx| %>
          <% next_record = @trackers[idx + 1] %>
          <% date_changed = (next_record && next_record.date != record.date) %>
          <tr class="border-b <%= 'border-b-2 border-gray-400' if date_changed %> bg-white">
            <td class="text-sky-700 text-sm text-center p-2 font-semibold"><%= idx + 1 %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.date.strftime("%Y-%m-%d") %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.feed_time&.strftime("%H:%M") %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.hungry.present? ? t("trackers.hungry_options.#{record.hungry}") : "" %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.come_back_to_eat %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= t("trackers.food_types.#{record.food_type.downcase}") %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.brand %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.description %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.amount %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.left_amount %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.total_ate_amount %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.result %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.weight %></td>
            <td class="text-sky-700 text-sm text-center p-2"><%= record.note %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex justify-center mt-8 italic text-gray-500">
    <%= will_paginate @trackers %>
  </div>
</div>
