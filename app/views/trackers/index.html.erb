<% content_for :title, t('trackers.index.title', petname: @pet.petname.capitalize) %>

  <details class="container mx-auto border-2 border-garyishBlue rounded-md shadow-md w-full lg:w-1/2">
    <summary class="text-center font-bold text-lg cursor-pointer p-2 md:text-base"><%= t('trackers.index.import_csv') %></summary>
    <div class="flex flex-col justify-center items-center mb-4">
      <%= form_with url: import_pet_trackers_path(@pet), method: :post do |form| %>
        <%= form.file_field :file, accept: ".csv" %>
        <%= form.button t('trackers.index.import_button'), class: "p-2 mt-4 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700 hover:scale-110" %>
        <div class="flex text-sm italic font-semibold text-gray-400">
          <span class="dark:text-grayishBlue"><%= t('trackers.index.import_hint') %></span>
        </div>
      <% end %>
    </div>
  </details>
  
  <div class="flex flex-col justify-center items-center mb-3">
    <h1 class="font-bold text-center text-2xl mt-5 md:text-4xl"><%= t('trackers.index.title', petname: @pet.petname.capitalize) %></h1>
    
    <%# Share and Download Section %>
    <div class="flex flex-row gap-4 mt-4" data-controller="share-and-download" 
         data-share-and-download-share-url-value="<%= @pet.share_token.present? ? shared_pet_trackers_url(share_token: @pet.share_token) : '' %>"
         data-share-and-download-chart-id-value="pet-chart"
         data-share-and-download-filename-value="<%= @pet.petname %>_feeding_chart">
      
      <% if @pet.share_token.present? %>
        <button data-action="click->share-and-download#copy" class="flex items-center space-x-2 px-4 py-2 bg-amber-100 text-amber-800 rounded-full border border-amber-300 hover:bg-amber-200 transition-colors shadow-sm font-bold text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          <span data-share-and-download-target="buttonText"><%= t('trackers.index.share_link') %></span>
        </button>
      <% end %>

      <button data-action="click->share-and-download#download" class="flex items-center space-x-2 px-4 py-2 bg-sky-100 text-sky-800 rounded-full border border-sky-300 hover:bg-sky-200 transition-colors shadow-sm font-bold text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span><%= t('trackers.index.download_chart') %></span>
      </button>
    </div>
  </div>

  <div class="flex flex-row justify-center space-x-3">
    <%= image_tag('add_tracker_removebg.png', width:'40px', height: '40px') %>
    <%= link_to t('trackers.index.new_tracker_link', petname: @pet.petname.capitalize), new_pet_tracker_path(@pet), class: "text-purple-500 text-lg underline decoration-2 decoration-purple-500 font-bold transition duration-300 ease-in-out hover:scale-110 capitalize md:text-xl" %>
  </div>

  <fieldset class="flex flex-row gap-3 justify-center mb-3">
    <%= image_tag('download.png', width: '25px', height: '25px') %>
    <%= link_to t('trackers.index.export_csv'), pet_trackers_path(@pet, format: :csv), class: "text-base font-bold text-sky-500 transition duration-300 ease-in-out hover:scale-110 capitalize md:text-lg dark:text-white" %>
  </fieldset>

  <div class="flex flex-col digg_pagination justify-center italic mt-4">
    <div class="flex justify-center page_info">
      <%= page_entries_info @trackers %>
    </div>

    <div class="flex digg_pagination justify-center mt-4">
      <%= will_paginate @trackers, :container => true %>
    </div>
    <div class="flex justify-end items-start mx-8">
      <%= form_with url: pet_trackers_path(@pet), method: :get, class: "flex items-center" do |form| %>
        <span class="mr-2"><%= t('trackers.index.items_per_page') %></span>
        <%= form.select :per_page, options_for_select([5, 10, 20, 50], (params[:per_page] || 10).to_i), {}, { onchange: 'this.form.submit()', class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700" } %>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col mt-5 mb-4 justify-center items-center mx-auto w-full">
    <div class="flex justify-end items-end pr-8 pt-4 mb-4 w-full" data-controller="range-form">
      <div class="relative">
        <div class="inline-flex w-full justify-center px-3 py-2 inset-ring-1 inset-ring-gray-300 cursor-pointer">
          <%= form_with url: pet_trackers_path(@pet), method: :get, class: "flex items-center" do |form| %>
            <span class="mr-2"><%= t('trackers.index.chart_range') %></span>
            <%= form.select :range, options_for_select([[t('trackers.index.all_time'), "all"], [t('trackers.index.last_7_days'), "7"], 
            [t('trackers.index.last_30_days'), "30"], [t('trackers.index.last_120_days'), "120"], [t('trackers.index.last_180_days'), "180"], [t('trackers.index.year_to_date'), "YTD"], [t('trackers.index.custom'), "custom"]], params[:range] || "all"), {}, 
            { data: { action: "change->range-form#toggleForm" }, class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 
            hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700" } %>
          <% end %>
        </div>
        <div data-range-form-target="form" class="absolute hidden w-max top-full mt-2 py-2 z-30">
          <%= form_with url: pet_trackers_path(@pet), method: :get, class: "flex items-center ml-4" do |form| %>
            <div class= "inline-flex w-full justify-center bg-white px-3 py-2 text-grayishBlue rounded-md shadow-lg tracking-wide inset-ring-1 inset-ring-gray-300 dark:bg-darkBlue cursor-pointer">
              <%= form.hidden_field :range, value: "custom" %>
                <div class="flex flex-col items-center gap-4">
                  <div class="flex items-center">
                    <span class="mr-2"><%= t('trackers.index.start_date') %></span>
                    <%= form.date_field :start_date, value: params[:start_date], class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200", min: @min_date, max: @max_date %>
                  </div>
                  <div class="flex items-center">
                    <span class="mr-2"><%= t('trackers.index.end_date') %></span>
                    <%= form.date_field :end_date, value: params[:end_date], class: "p-1 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200", min: @min_date, max: @max_date %>
                  </div>
                  <div class="flex items-center">
                    <%= form.submit t('trackers.index.apply_custom_range'), class: "p-2 ml-4 rounded-md shadow-lg font-semibold border-2 border-blue-300 text-gray-700 bg-sky-200 hover:bg-gray-200 hover:border-gray-400 hover:text-sky-700" %>
                  </div>
                </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="relative w-full px-8 py-8 md:px-12 md:py-12 mx-auto">
      <!-- Left Overlay (Amount) -->
      <div class="absolute left-2 md:left-4 top-[42%] w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block -rotate-90 capitalize whitespace-nowrap font-bold text-base text-gray-600 dark:text-gray-100">
          <%= t('trackers.index.chart_v_axis_amount') %>
        </span>
      </div>

      <!-- Right Overlay (Weight) -->
      <div class="absolute right-2 md:right-4 top-[42%] w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block -rotate-90 capitalize whitespace-nowrap font-bold text-base text-gray-600 dark:text-gray-100">
          <%= t('trackers.index.chart_v_axis_weight') %>
        </span>
      </div>

      <!-- Title Overlay (amount vs. weight) -->
      <div class="absolute left-1/2 -translate-x-1/2 top-4 w-0 h-0 flex items-center justify-center z-10 pointer-events-none">
        <span class="block capitalize whitespace-nowrap font-bold text-lg text-gray-700 dark:text-gray-200">
          <%= t('trackers.index.chart_title') %>
        </span>
      </div>

      <div class="relative w-full border border-gray-100 rounded-lg shadow-sm bg-white dark:bg-slate-800 overflow-hidden">
        
        <!-- 1. Scrolling Data Chart -->
        <div id="chart-container" class="w-full overflow-x-auto relative z-0 custom-scrollbar">
          <% chart_width = [@data.first[:data].size * 15, 800].max %>
          <div style="min-width: <%= chart_width%>px;">
            <% if @dry_properties.present? || @wet_properties.present? %>
              <%= column_chart @data, adapter: "google", height: "350px", id: "pet-chart-scrolling", library: {
                isStacked: true,
                interpolateNulls: true,
                series: {
                  0 => {type: 'bar', targetAxisIndex: 0},
                  1 => {type: 'bar', targetAxisIndex: 0},
                  2 => {type: 'bar', targetAxisIndex: 0},
                  3 => {type: 'bar', targetAxisIndex: 0},
                  4 => {type: 'line', targetAxisIndex: 1, pointSize: 5}
                },
                colors: ['#C1D7EC', '#2563EB', '#FFDAB9','#F97316', '#6B4AB9'],
                bar: {groupWidth: '75%'},
                chartArea: {left: 60, right: 60, bottom: 100, top: 40},
                hAxis: {
                  title: t('trackers.index.chart_h_axis_title'),
                  showTextEvery: @chart_interval,
                  slantedText: true,
                  slantedTextAngle: 45,
                  format: 'yyyy/MM/dd',
                  textStyle: {fontSize: 8}
                },
                vAxes: {
                  0 => {title: "", textPosition: 'none'},
                  1 => {title: "", textPosition: 'none', viewWindow: {min: @min_weight, max: @max_weight}, gridlines: {color: 'transparent'}}
                },
                legend: {position: 'top', alignment: 'center'}
              } %>
            <% else %>            
              <div class="text-center p-8 my-4 bg-gray-100 rounded-lg shadow-lg">
                <p class="font-semibold text-gray-700"><%= t('trackers.index.no_data_for_chart') %></p>
              </div>
            <% end %>
          </div>
        </div>

        <% if @dry_properties.present? || @wet_properties.present? %>
          <!-- 2. Solid Background Masks (Hides bars scrolling under axes) -->
          <div class="absolute left-0 top-[40px] bottom-[100px] w-[60px] bg-white z-10 pointer-events-none"></div>
          <div class="absolute right-0 top-[40px] bottom-[100px] w-[60px] bg-white z-10 pointer-events-none"></div>

          <!-- 3. Fixed Axes Chart Overlay -->
          <div class="absolute inset-0 z-20 pointer-events-none">
            <%= column_chart @data, adapter: "google", height: "350px", id: "pet-chart-fixed", library: {
              isStacked: true,
              interpolateNulls: true,
              series: {
                0 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                1 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                2 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                3 => {type: 'bar', targetAxisIndex: 0, visibleInLegend: false},
                4 => {type: 'line', targetAxisIndex: 1, visibleInLegend: false}
              },
              colors: ['transparent', 'transparent', 'transparent', 'transparent', 'transparent'],
              backgroundColor: 'transparent',
              chartArea: {left: 60, right: 60, bottom: 100, top: 40},
              hAxis: { textPosition: 'none', baselineColor: 'transparent', gridlines: {color: 'transparent'} },
              vAxes: {
                0 => {title: "", gridlines: {color: 'transparent'}},
                1 => {title: "", viewWindow: {min: @min_weight, max: @max_weight}, gridlines: {color: 'transparent'}}
              },
              legend: {position: 'none'}
            } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div id="trackers" class="container mx-auto flex flex-col divide-y divide-gray-200 space-y-5">
    <%= form_with url: pet_trackers_path(@pet), method: :get, data: { controller: "filter-form" } do |form| %>
      <div class="flex flex-row gap-4">
        <div class="flex items-center mt-4">
          <%= form.label :food_type, t('trackers.index.food_type'), class: "text-sm font-medium text-gray-700 p-4 dark:text-gray-100 capitalize md:text-base whitespace-nowrap" %>
          <%= form.text_field :food_type, value: params[:food_type], class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full dark:text-black", data: { action: "input->filter-form#submit" } %>
        </div>
        <div class="flex items-center mt-4">
          <%= form.label :brand, t('trackers.index.brand'), class: "text-sm font-medium text-gray-700 p-4 dark:text-gray-100 capitalize md:text-base" %>
          <%= form.text_field :brand, value: params[:brand], class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full dark:text-black", data: { action: "input->filter-form#submit" } %>
        </div>
        <div class="flex items-center mt-4">
          <%= form.label :description, t('trackers.index.description'), class: "text-sm font-medium text-gray-700 p-4 dark:text-gray-100 capitalize md:text-base" %>
          <%= form.text_field :description, value: params[:description], class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full dark:text-black", data: { action: "input->filter-form#submit" } %>
        </div>
        <div class="flex items-center mt-4">
          <%= form.label :note, t('trackers.index.note'), class: "text-sm font-medium text-gray-700 p-4 dark:text-gray-100 capitalize md:text-base" %>
          <%= form.text_field :note, value: params[:note], class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full dark:text-black", data: { action: "input->filter-form#submit" } %>
        </div>
        <div class="flex items-center mt-4">
          <%= link_to t('trackers.index.clear'), pet_trackers_path(@pet), class: "py-2 px-3 mt-2 rounded-md shadow-lg font-semibold border-2 border-gray-300 text-gray-700 bg-gray-200 hover:bg-gray-300 hover:border-gray-400 hover:text-gray-600 hover:bg-gray-100 hover:scale-110" %>
        </div>
      </div>
    <% end %>

    <%= form_with url: bulk_delete_pet_trackers_path(@pet), method: :delete, data: { confirm: t('trackers.index.confirm_delete') } do |form| %>
      <% if @trackers.any?%>
        <div class="flex justify-start mt-4">
          <%= form.submit t('trackers.index.delete_selected'), class: "p-2 rounded-md shadow-lg font-semibold border-2 border-red-300 text-gray-700 bg-red-200 hover:bg-gray-100 hover:border-gray-300 hover:text-red-700 hover:scale-110" %>
        </div>
        <%= render 'tracker' %>
      <% else %>
        <p class="text-lg text-center my-10"><%= t('trackers.index.no_trackers_found', petname: @pet.petname.capitalize) %></p>
      <% end %>
    <% end %>
  </div>

  <div class="flex digg_pagination justify-center mb-4 mt-4">
    <div class="page_info italic">
      <%= page_entries_info @trackers %>
    </div>
  </div>
  <div class="flex digg_pagination justify-center mt-4 mb-4 italic">
    <%= will_paginate @trackers, :container => true %>
  </div>
</div>