<% content_for :title, t('trackers.edit.title', petname: @pet.petname.capitalize) %>

<div class="container mx-auto md:w-2/3 w-full">
  <div class="flex flex-row justify-center gap-4 mb-4 p-4 sm:p-6">
    <%= image_tag('tracker_removebg.png', width: '48px', height: '40px') %>
    <h1 class="text-center font-bold text-2xl mt-4 capitalize lg:text-4xl"><%= t('trackers.edit.header', petname: @pet.petname) %></h1>
  </div>

  <%= form_with(model: [@pet, @tracker], id: "left-amount", class: "contents", data: { controller: "left-amount" }) do |form| %>
    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <%= render 'shared/errors', obj: @tracker %>
    </div>
    <%= form.hidden_field :page, value: params[:page] %>
    
    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :date, t('trackers.form.date'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.date_field :date, value: @tracker.date, class: "input-field mt-2" %>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :feed_time, t('trackers.form.feed_time'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="relative flex flex-col items-center md:items-start md:w-5/6">
        <%= form.time_field :feed_time, value: @tracker.feed_time.strftime("%H:%M"), data: { left_amount_target: "feed_time" }, class: "input-field mt-0 pr-10 bg-gray-100 dark:bg-gray-300", readonly: true %>
        <div class="relative flex flex-col justify-end items-end w-full px-4">
          <button type="button" data-action="click->left-amount#toggleReadonly" data-target-name="feed_time" class="absolute right-2 -translate-y-1/2 z-10 text-gray-400 hover:text-softBlue transition-all duration-300" title="Edit Feed Time">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :come_back_to_eat, t('trackers.tracker.come_back_to_eat'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.text_field :come_back_to_eat, class: "input-field mt-2" %>
        <span class="mt-2 text-sm italic"><%= t('trackers.edit.come_back_to_eat_hint_html', petname: h(@pet.petname.capitalize)).html_safe %></span>
      </div>
    </div>

    <% if @tracker.dry_food_id.present? %>
      <div class="hidden flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <%= form.label :dry_food_id, "Dry Food Id", class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-5/6">
          <%= form.text_field :dry_food_id, value: @tracker.dry_food_id, class: "input-field mt-2" %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :brand, t('trackers.form.brand'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.text_field :brand, value: @tracker.brand, data: { left_amount_target: "brand" }, class: "input-field mt-0 pr-10 bg-gray-100 dark:bg-gray-300", readonly: true %>
        <div class="relative flex flex-col justify-end items-end w-full px-4">
          <button type="button" data-action="click->left-amount#toggleReadonly" data-target-name="brand" class="absolute right-2 -translate-y-1/2 text-gray-400 hover:text-softBlue transition-all duration-300" title="Edit Brand">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :description, t('trackers.form.description'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.text_field :description, value: @tracker.description, data: { left_amount_target: "description" }, class: "input-field mt-0 pr-10 bg-gray-100 dark:bg-gray-300", readonly: true %>
        <div class="relative flex flex-col justify-end items-end w-full px-4">
          <button type="button" data-action="click->left-amount#toggleReadonly" data-target-name="description" class="absolute right-2 -translate-y-1/2 text-gray-400 hover:text-softBlue transition-all duration-300" title="Edit Description">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :hungry, t('trackers.form.hungry'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.select :hungry, Tracker.hungries.keys.map { |key| [t("trackers.hungry_options.#{key}"), key] }, { prompt: t('trackers.form.hungry_prompt', petname: @pet.petname.capitalize) }, required: true, class: "input-field mt-2" %>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :love, t('trackers.edit.love_prompt', petname: @pet.petname.capitalize), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.select :love, [t('trackers.edit.love_option_1'), t('trackers.edit.love_option_2'), t('trackers.edit.love_option_3')], { prompt: t('trackers.edit.select_love_prompt', petname: @pet.petname.capitalize) }, class: "input-field mt-2"%>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :amount, t('trackers.form.amount'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.number_field :amount, value: @tracker.amount, data: { left_amount_target: "amount" }, class: "input-field mt-0 pr-10 bg-gray-100 dark:bg-gray-300", readonly: true %>
        <div class="relative flex flex-col justify-end items-end w-full px-4">
          <button type="button" data-action="click->left-amount#toggleReadonly" data-target-name="amount" class="absolute right-2 -translate-y-1/2 text-gray-400 hover:text-softBlue transition-all duration-300" title="Edit Amount">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :left_amount, t('trackers.edit.left_amount'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize required md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.number_field :left_amount, step: :any, placeholder: t('trackers.form.amount_placeholder'), class: "input-field mt-2", min: 0, max: @tracker.amount, data: { left_amount_target: "leftAmount", action: "input->left-amount#validateLeftAmount" } %>
        <span class="mt-2 text-sm italic"><%= t('trackers.edit.feeding_amount') %> <%= @tracker.amount %>(g)</span>
        <div class="flex items-center mt-1">
          <div id="left-amount-alert" data-left-amount-target="leftAmountAlert" class="text-red-500 italic hidden"></div>
          <span data-left-amount-target="separator" class="mx-1 text-green-500 hidden">/</span>
          <div id="total-ate-amount" data-left-amount-target="totalAteAmount" class="text-green-500 italic hidden"></div>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :weight, t('trackers.edit.weight'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.number_field :weight, step: :any, placeholder: t('trackers.edit.weight_placeholder'), class: "input-field mt-2", max: 100, min: 0.0 %>
      </div>
    </div>

    <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
      <div class="flex justify-center md:justify-end md:w-1/3">
        <%= form.label :note, t('trackers.edit.note'), class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
      </div>
      <div class="flex flex-col items-center md:items-start md:w-5/6">
        <%= form.text_field :note, class: "input-field mt-2" %>
        <span><%= t('trackers.edit.note_hint', petname: @pet.petname.capitalize) %></span>
      </div>
    </div>

    <div class="flex flex-col justify-center items-center space-x-4 mb-4 md:flex-row">
      <div class="mb-4">
        <%= form.submit t('trackers.edit.update_button'), class: "text-center rounded-md px-3.5 py-2.5 text-white bg-softBlue hover:bg-white hover:text-softBlue hover:border-2 hover:border-softBlue inline-block font-medium cursor-pointer", data: { left_amount_target: "submitButton" } %>
      </div>
      <div class="mb-4">
        <%= link_to t('trackers.edit.cancel_button', petname: @pet.petname.capitalize), pet_trackers_path(@pet, page: params[:page]), class: "text-center rounded-md px-3.5 py-2.5 text-white bg-grayishBlue hover:bg-white hover:text-grayishBlue hover:border-2 hover:border-grayishBlue inline-block font-medium cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>