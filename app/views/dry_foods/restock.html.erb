<% content_for :title, "Restock Dry Food" %>

<div class="container mx-auto px-4 w-full mb-4 mt-2 md:w-3/4 lg:w-2/3">
  <div class="flex flex-col justify-center bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 shadow-md rounded-lg p-4 sm:p-6">
    <div class="mx-auto mb-6">
      <h1 class="text-center font-bold text-2xl mb-4 capitalize underline underline-offset-4 md:text-4xl">Restock</h1>
      <h3 class="text-center font-semibold text-xl capitaliz mt-4 md:text-2xl"><%= @dry_food.brand %> - <%= @dry_food.description %></h3>
    </div>

    <%= form_with(model: @dry_food, url: restock_dry_food_path(@dry_food), method: :patch) do |form| %>
      <% if @dry_food.errors.any? %>
        <div class="text-red-500">
          <h2><%= pluralize(@dry_food.errors.count, "error") %> prohibited this dry_food from being saved:</h2>
          <ul>
            <% @dry_food.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col justify-center space-x-3 items-center mb-4 md:flex-row">
        <div class="flex justify-center md:justify-end md:w-1/3">
          <%= form.label :amount, class: "text-sm font-medium text-gray-700 dark:text-gray-100 capitalize md:text-base" %>
        </div>
        <div class="flex flex-col items-center md:items-start md:w-2/3">
          <%= form.number_field :amount, class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full dark:text-black dark:bg-gray-100", step: :any, min: 0, max: 15000, placeholder: "The amount of restock bag" %>
        </div>
      </div>

      <div class="flex flex-col justify-center items-center space-x-4 mb-4 md:flex-row">
        <div class="mb-4">
          <%= form.submit "Submit", class: "bg-softBlue text-white font-bold py-2 px-4 mb-2 rounded-md cursor-pointer transition duration-300 ease-in-out hover:scale-110" %>
        </div>
        <div class="mb-4">
          <%= link_to "Cancel", dry_foods_path, class: "text-center rounded-md px-4 py-2 mb-2 text-white bg-grayishBlue hover:bg-white hover:text-grayishBlue hover:border-2 hover:border-grayishBlue inline-block font-medium cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
