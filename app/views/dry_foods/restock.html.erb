<% content_for :title, t('.title') %>

<div class="container mx-auto px-4 w-full md:w-3/4 lg:w-2/3">
  <div class="flex flex-col justify-center items-center">
    <h1 class="text-center font-bold text-2xl mt-5 capitalize md:text-4xl"><%= t('.header') %></h1>
  </div>

  <%= form_with(model: @dry_food, url: restock_dry_food_path(@dry_food), method: :patch) do |form| %>
    <% if @dry_food.errors.any? %>
      <div class="text-red-500">
        <h2><%= pluralize(@dry_food.errors.count, "error") %> prohibited this dry_food from being saved:</h2>
        <ul>
          <% @dry_food.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :brand, class: "block font-medium mb-1" %>
      <%= form.text_field :brand, readonly: true, class: "w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="my-5">
      <%= form.label :description, class: "block font-medium mb-1" %>
      <%= form.text_field :description, readonly: true, class: "w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="my-5">
      <%= form.label :amount, class: "block font-medium mb-1" %>
      <%= form.number_field :amount, class: "w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="flex justify-center items-center">
      <%= form.submit t('.submit'), class: "bg-sky-500 text-white font-bold py-2 px-4 rounded-md cursor-pointer transition duration-300 ease-in-out hover:bg-sky-600" %>
    </div>
  <% end %>
</div>
