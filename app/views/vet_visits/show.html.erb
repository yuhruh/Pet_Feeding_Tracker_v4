<%# Redirect or show details of the single vet visit %>
<% content_for :title, t('.title', petname: @pet.petname.capitalize) %>

<div class="container mx-auto md:w-2/3 w-full p-4">
  <div class="bg-white dark:bg-gray-900 border-4 border-amber-600 rounded-lg shadow-2xl p-6">
    <h1 class="font-bold text-2xl text-amber-700 dark:text-amber-500 mb-4"><%= t('.visit_details') %></h1>
    <div class="space-y-4">
      <p><strong><%= t('.visit_date') %>:</strong> <%= @vet_visit.visit_date %></p>
      <p><strong><%= t('.question') %>:</strong> <%= @vet_visit.question %></p>
      <p><strong><%= t('.answer') %>:</strong> <%= @vet_visit.answer.presence || t('.no_answer_yet') %></p>
    </div>
    <div class="mt-6 flex gap-4">
      <%= link_to t('.edit'), edit_pet_vet_visit_path(@pet, @vet_visit), class: "text-center rounded-md px-4 py-2 text-white bg-green-600 hover:bg-green-700 font-bold transition duration-300" %>
      <%= link_to t('.back'), pet_vet_visits_path(@pet), class: "text-center rounded-md px-4 py-2 text-white bg-gray-500 hover:bg-gray-600 font-bold transition duration-300" %>
    </div>
  </div>
</div>
